@model IEnumerable<DraftApp.Models.Course>

@{
    ViewData["Title"] = "Course Registry";
}

<style>
    :root {
        --f-bg-color: #0b0f19;
        --f-card-bg: rgba(17, 24, 39, 0.6);
        --f-card-border: rgba(56, 189, 248, 0.15);
        --f-text-primary: #f3f4f6;
        --f-text-secondary: #9ca3af;
        --f-accent: #38bdf8;
        --f-accent-glow: rgba(56, 189, 248, 0.3);
        --f-success: #10b981;
        --f-danger: #f43f5e;
    }

    .f-index-wrapper {
        background: radial-gradient(circle at bottom right, #1e1b4b, var(--f-bg-color));
        padding: 2.5rem;
        border-radius: 20px;
        color: var(--f-text-primary);
        font-family: 'Inter', 'Segoe UI', sans-serif;
        min-height: 85vh;
    }

    /* Header & Action Bar */
    .f-action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .f-title-group h1 {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0;
        background: linear-gradient(135deg, #fff 30%, var(--f-accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Table Replacement: Futuristic Rows */
    .f-table-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .f-table-header {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1.5fr;
        padding: 0 1.5rem;
        color: var(--f-text-secondary);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-weight: 700;
    }

    .f-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1.5fr;
        align-items: center;
        padding: 1.25rem 1.5rem;
        background: var(--f-card-bg);
        border: 1px solid var(--f-card-border);
        border-radius: 12px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        backdrop-filter: blur(8px);
    }

        .f-row:hover {
            transform: scale(1.01) translateX(5px);
            background: rgba(56, 189, 248, 0.05);
            border-color: var(--f-accent);
            box-shadow: -5px 0 20px var(--f-accent-glow);
        }

    /* Column Styles */
    .f-col-title {
        font-weight: 600;
        color: #fff;
        font-size: 1.1rem;
    }

    .f-col-fee {
        color: var(--f-accent);
        font-weight: 700;
        font-family: 'Courier New', monospace;
    }

    /* Status Indicators */
    .f-status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .status-dot {
        height: 8px;
        width: 8px;
        border-radius: 50%;
    }

    .status-active {
        color: var(--f-success);
    }

        .status-active .status-dot {
            background: var(--f-success);
            box-shadow: 0 0 8px var(--f-success);
        }

    .status-inactive {
        color: var(--f-text-secondary);
    }

        .status-inactive .status-dot {
            background: #4b5563;
        }

    /* Action Links */
    .f-row-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }

    .f-link {
        font-size: 0.8rem;
        text-decoration: none;
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        transition: 0.2s;
        border: 1px solid transparent;
    }

    .link-edit {
        color: var(--f-accent);
    }

        .link-edit:hover {
            background: rgba(56, 189, 248, 0.15);
            border-color: var(--f-accent);
        }

    .link-details {
        color: var(--f-text-primary);
    }

        .link-details:hover {
            background: rgba(255, 255, 255, 0.1);
        }

    .link-delete {
        color: var(--f-danger);
    }

        .link-delete:hover {
            background: rgba(244, 63, 94, 0.15);
            border-color: var(--f-danger);
        }

    .f-btn-create {
        background: var(--f-accent);
        color: #000 !important;
        padding: 0.8rem 1.5rem;
        border-radius: 10px;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 0 20px var(--f-accent-glow);
        transition: 0.3s;
    }

        .f-btn-create:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 25px var(--f-accent-glow);
        }

    @@media (max-width: 992px) {
        .f-table-header {
            display: none;
        }

        .f-row {
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .f-row-actions {
            grid-column: span 2;
            justify-content: flex-start;
            border-top: 1px solid var(--f-card-border);
            padding-top: 1rem;
        }
    }
</style>

<div class="f-index-wrapper">
    <div class="f-action-bar">
        <div class="f-title-group">
            <h1>Course Registry</h1>
            <span style="color: var(--f-text-secondary); font-size: 0.9rem;">Total Records: @Model.Count()</span>
        </div>
        <a asp-action="Create" class="f-btn-create">+ Deploy New Course</a>
    </div>

    <div class="f-table-container">
        <div class="f-table-header">
            <div>Course Identity</div>
            <div>Duration</div>
            <div>Investment</div>
            <div>Complexity</div>
            <div>Status</div>
            <div style="text-align: right;">Authorization</div>
        </div>

        @foreach (var item in Model)
        {
            <div class="f-row">
                <div class="f-col-title">@Html.DisplayFor(modelItem => item.Title)</div>

                <div class="f-text-secondary">@item.DurationDays Days</div>

                <div class="f-col-fee">$@item.Fee</div>

                <div>
                    <span style="background: rgba(255,255,255,0.05); padding: 2px 8px; border-radius: 4px; font-size: 0.85rem;">
                        @item.Level
                    </span>
                </div>

                <div class="f-status @(item.IsActive ? "status-active" : "status-inactive")">
                    <div class="status-dot"></div>
                    @(item.IsActive ? "Online" : "Offline")
                </div>

                <div class="f-row-actions">
                    <a asp-action="Edit" asp-route-id="@item.CourseId" class="f-link link-edit">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.CourseId" class="f-link link-details">View</a>
                    <a asp-action="Delete" asp-route-id="@item.CourseId" class="f-link link-delete">Remove</a>
                </div>
            </div>
        }
    </div>
</div>