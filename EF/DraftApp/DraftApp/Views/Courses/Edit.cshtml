@model DraftApp.Models.Course

@{
    ViewData["Title"] = "Update Configuration";
}

<style>
    :root {
        --f-bg-color: #0b0f19;
        --f-card-bg: rgba(17, 24, 39, 0.7);
        --f-card-border: rgba(56, 189, 248, 0.2);
        --f-text-primary: #f3f4f6;
        --f-text-secondary: #9ca3af;
        --f-accent: #38bdf8;
        --f-accent-glow: rgba(56, 189, 248, 0.4);
        --f-danger: #ef4444;
        --f-input-bg: rgba(255, 255, 255, 0.03);
    }

    .f-edit-wrapper {
        background: radial-gradient(circle at top left, #1e1b4b, var(--f-bg-color));
        padding: 3rem 2rem;
        border-radius: 16px;
        color: var(--f-text-primary);
        font-family: 'Inter', 'Segoe UI', sans-serif;
        box-shadow: inset 0 0 100px rgba(0,0,0,0.5);
    }

    .f-header {
        margin-bottom: 2rem;
        border-bottom: 1px solid var(--f-card-border);
        padding-bottom: 1rem;
    }

        .f-header h1 {
            font-size: 2.2rem;
            font-weight: 700;
            background: linear-gradient(to right, #fff, var(--f-accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .f-form-card {
        background: var(--f-card-bg);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid var(--f-card-border);
        border-radius: 12px;
        padding: 2.5rem;
        max-width: 700px;
    }

    .f-form-group {
        margin-bottom: 1.5rem;
    }

    .f-label {
        display: block;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--f-text-secondary);
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .f-input {
        width: 100%;
        background: var(--f-input-bg);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--f-text-primary);
        padding: 0.8rem 1rem;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

        .f-input:focus {
            outline: none;
            border-color: var(--f-accent);
            box-shadow: 0 0 15px var(--f-accent-glow);
            background: rgba(0, 0, 0, 0.2);
        }

    /* Toggle Switch Styling */
    .f-switch {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 24px;
        margin-right: 10px;
    }

        .f-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .f-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #374151;
        transition: .4s;
        border-radius: 34px;
    }

        .f-slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

    input:checked + .f-slider {
        background-color: var(--f-accent);
    }

        input:checked + .f-slider:before {
            transform: translateX(26px);
        }

    /* Action Buttons */
    .f-actions {
        display: flex;
        gap: 1.5rem;
        margin-top: 2rem;
        align-items: center;
    }

    .f-btn-save {
        background: var(--f-accent);
        color: #000;
        padding: 0.8rem 2.5rem;
        border-radius: 8px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        box-shadow: 0 0 15px var(--f-accent-glow);
        transition: 0.3s;
    }

        .f-btn-save:hover {
            transform: scale(1.03);
            box-shadow: 0 0 25px var(--f-accent-glow);
        }

    .f-link-back {
        color: var(--f-text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        transition: 0.3s;
    }

        .f-link-back:hover {
            color: #fff;
        }

    .f-validation {
        color: var(--f-danger);
        font-size: 0.8rem;
        margin-top: 0.3rem;
    }
</style>

<div class="f-edit-wrapper">
    <div class="f-header">
        <h1>Modify Protocol</h1>
        <p style="color: var(--f-text-secondary);">Editing Course ID: @Model.CourseId</p>
    </div>

    <div class="f-form-card">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="f-validation" style="margin-bottom:1rem;"></div>
            <input type="hidden" asp-for="CourseId" />

            <div class="f-form-group">
                <label asp-for="Title" class="f-label"></label>
                <input asp-for="Title" class="f-input" />
                <span asp-validation-for="Title" class="f-validation"></span>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="f-form-group">
                    <label asp-for="DurationDays" class="f-label"></label>
                    <input asp-for="DurationDays" class="f-input" />
                    <span asp-validation-for="DurationDays" class="f-validation"></span>
                </div>

                <div class="f-form-group">
                    <label asp-for="Fee" class="f-label"></label>
                    <input asp-for="Fee" class="f-input" />
                    <span asp-validation-for="Fee" class="f-validation"></span>
                </div>
            </div>

            <div class="f-form-group">
                <label asp-for="Level" class="f-label"></label>
                <input asp-for="Level" class="f-input" />
                <span asp-validation-for="Level" class="f-validation"></span>
            </div>

            <div class="f-form-group">
                <label asp-for="CreatedAt" class="f-label"></label>
                <input asp-for="CreatedAt" class="f-input" readonly style="opacity: 0.6; cursor: not-allowed;" />
                <span asp-validation-for="CreatedAt" class="f-validation"></span>
            </div>

            <div class="f-form-group" style="display: flex; align-items: center; background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px;">
                <label class="f-switch">
                    <input asp-for="IsActive" type="checkbox" />
                    <span class="f-slider"></span>
                </label>
                <span style="font-weight: 600; font-size: 0.9rem;">Deployment Status (Active)</span>
            </div>

            <div class="f-actions">
                <button type="submit" class="f-btn-save">Sync Changes</button>
                <a asp-action="Index" class="f-link-back">Discard Changes</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}