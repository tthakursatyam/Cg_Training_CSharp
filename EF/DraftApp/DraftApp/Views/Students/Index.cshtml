

@model IEnumerable<DraftApp.Models.Student>

@{
    ViewData["Title"] = "Personnel Registry";
}

<style>
    :root {
        --s-bg: #0d1117;
        --s-card-bg: rgba(22, 27, 34, 0.8);
        --s-accent: #79c0ff;
        --s-accent-glow: rgba(121, 192, 255, 0.2);
        --s-border: rgba(48, 54, 61, 0.6);
        --s-text-primary: #f0f6fc;
        --s-text-muted: #8b949e;
        --s-row-hover: rgba(121, 192, 255, 0.05);
    }

    .s-index-wrapper {
        background: radial-gradient(circle at bottom right, #161b22, var(--s-bg));
        padding: 2.5rem;
        border-radius: 20px;
        color: var(--s-text-primary);
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 90vh;
    }

    /* Top Bar Styling */
    .s-top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
    }

    .s-title-group h1 {
        font-size: 2.4rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -1px;
        background: linear-gradient(to right, #fff, var(--s-accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .s-title-group p {
        color: var(--s-text-muted);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-top: 5px;
    }

    /* Action Button */
    .s-btn-create {
        background: var(--s-accent);
        color: #0d1117 !important;
        padding: 0.8rem 1.8rem;
        border-radius: 8px;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 0 15px var(--s-accent-glow);
        transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .s-btn-create:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 8px 25px var(--s-accent-glow);
        }

    /* Futuristic Table Structure */
    .s-registry-grid {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .s-grid-header {
        display: grid;
        grid-template-columns: 2fr 2fr 1.5fr 1fr 1.5fr 1.5fr;
        padding: 1rem 1.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--s-text-muted);
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .s-grid-row {
        display: grid;
        grid-template-columns: 2fr 2fr 1.5fr 1fr 1.5fr 1.5fr;
        align-items: center;
        background: var(--s-card-bg);
        border: 1px solid var(--s-border);
        border-radius: 12px;
        padding: 1.2rem 1.5rem;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

        .s-grid-row:hover {
            border-color: var(--s-accent);
            background: var(--s-row-hover);
            transform: scale(1.005) translateX(10px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }

    /* Data Points */
    .s-name {
        font-weight: 700;
        color: #fff;
        font-size: 1.05rem;
    }

    .s-email {
        color: var(--s-accent);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.9rem;
    }

    .s-status {
        font-size: 0.8rem;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 4px;
        background: rgba(255,255,255,0.05);
        text-align: center;
    }

    /* Action Links */
    .s-row-actions {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
    }

    .s-action-link {
        color: var(--s-text-muted);
        text-decoration: none;
        font-size: 0.85rem;
        transition: 0.2s;
        padding: 5px 10px;
        border-radius: 6px;
    }

        .s-action-link:hover {
            color: #fff;
            background: rgba(255,255,255,0.1);
        }

        .s-action-link.delete:hover {
            color: #ff7b72;
            background: rgba(255,123,114,0.1);
        }

    @@media (max-width: 1100px) {
        .s-grid-header {
            display: none;
        }

        .s-grid-row {
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .s-row-actions {
            grid-column: span 2;
            border-top: 1px solid var(--s-border);
            padding-top: 1rem;
            margin-top: 0.5rem;
        }
    }
</style>

<div class="s-index-wrapper">
    <div class="s-top-bar">
        <div class="s-title-group">
            <h1>Personnel Registry</h1>
            <p>Active Student Directory / Secure Access</p>
        </div>
        <a asp-action="Create" class="s-btn-create">+ Add Personnel</a>
    </div>

    <div class="s-registry-grid">
        <div class="s-grid-header">
            <div>Full Name</div>
            <div>Email Architecture</div>
            <div>Contact</div>
            <div style="text-align: center;">Status</div>
            <div>Join Date</div>
            <div style="text-align: right;">System Control</div>
        </div>

        @foreach (var item in Model)
        {
            <div class="s-grid-row">
                <div class="s-name">@Html.DisplayFor(modelItem => item.FullName)</div>
                <div class="s-email">@Html.DisplayFor(modelItem => item.Email)</div>
                <div class="s-text-muted" style="font-size: 0.9rem;">@Html.DisplayFor(modelItem => item.Phone)</div>
                <div class="s-status">@Html.DisplayFor(modelItem => item.Status)</div>
                <div class="s-text-muted" style="font-size: 0.9rem;">@item.JoinDate.ToString("MMM dd, yyyy")</div>

                <div class="s-row-actions">
                    <a asp-action="Edit" asp-route-id="@item.StudentId" class="s-action-link">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.StudentId" class="s-action-link">View</a>
                    <a asp-action="Delete" asp-route-id="@item.StudentId" class="s-action-link delete">Delete</a>
                </div>
            </div>
        }
    </div>
</div>



@*
@model List<Student>

@{
    ViewData["Title"] = "Students";
    var q = (ViewBag.Query as string) ?? "";
}

<div class="card">
    <div class="row">
        <div>
            <h2 style="margin:0">Students</h2>
            <div class="muted small">CRUD + Live Search (AJAX)</div>
        </div>
        <a class="btn" asp-action="Create">+ Add Student</a>
    </div>

    <div style="margin-top:10px" class="row">
        <input id="q" class="input" style="max-width:420px" placeholder="Search name/email..." value="@q" />
        <button id="btnSearch" class="btn" type="button">Search</button>
    </div>

    <div id="liveBox" style="margin-top:10px" class="small muted"></div>

    <table class="tbl">
        <thead>
            <tr><th>Id</th><th>Name</th><th>Email</th><th>Status</th><th style="width:200px">Actions</th></tr>
        </thead>
        <tbody id="tblBody">
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.StudentId</td>
                    <td>@s.FullName</td>
                    <td>@s.Email</td>
                    <td>@s.Status</td>
                    <td>
                        <a class="btn" asp-action="Edit" asp-route-id="@s.StudentId">Edit</a>
                        <a class="btn" asp-action="Delete" asp-route-id="@s.StudentId">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        const qEl = document.getElementById("q");
        const box = document.getElementById("liveBox");
        const tbody = document.getElementById("tblBody");
        const btn = document.getElementById("btnSearch");

        let t = null;

        function renderRows(items){
          if(!items || items.length === 0){
            tbody.innerHTML = `<tr><td colspan="5">No results</td></tr>`;
            return;
          }
          tbody.innerHTML = items.map(s => `
            <tr>
              <td>${s.studentId}</td>
              <td>${s.fullName}</td>
              <td>${s.email}</td>
              <td>${s.status}</td>
              <td>
                <a class="btn" href="/Students/Edit/${s.studentId}">Edit</a>
                <a class="btn" href="/Students/Delete/${s.studentId}">Delete</a>
              </td>
            </tr>
          `).join("");
        }

        async function liveSearch(){
          const q = qEl.value.trim();
          if(q.length === 0){
            box.textContent = "";
            return;
          }
          box.textContent = "Searching...";
          const res = await fetch(`/Students/Search?q=${encodeURIComponent(q)}`);
          const data = await res.json();
          box.textContent = `Found: ${data.length}`;
          renderRows(data);
        }

        qEl.addEventListener("keyup", () => {
          clearTimeout(t);
          t = setTimeout(liveSearch, 250);
        });
        btn.addEventListener("click", liveSearch);
    </script>
}
*@