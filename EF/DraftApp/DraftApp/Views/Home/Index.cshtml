@{
    ViewData["Title"] = "Command Center";
}

<style>
    :root {
        --h-bg: #05070a;
        --h-card: rgba(17, 24, 39, 0.8);
        --h-accent-blue: #38bdf8;
        --h-accent-purple: #818cf8;
        --h-border: rgba(255, 255, 255, 0.1);
        --h-text: #f3f4f6;
    }

    .h-dashboard-wrapper {
        background: radial-gradient(circle at top center, #111827, var(--h-bg));
        min-height: 90vh;
        padding: 4rem 1rem;
        color: var(--h-text);
        font-family: 'Inter', system-ui, sans-serif;
    }

    .h-hero-section {
        text-align: center;
        margin-bottom: 5rem;
    }

        .h-hero-section h1 {
            font-size: 4rem;
            font-weight: 900;
            letter-spacing: -2px;
            background: linear-gradient(to bottom, #fff 40%, var(--h-accent-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1rem;
        }

    .h-status-line {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
        color: var(--h-accent-blue);
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 4px;
        font-weight: 600;
    }

    .h-pulse-dot {
        height: 8px;
        width: 8px;
        background-color: var(--h-accent-blue);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--h-accent-blue);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(0.95);
            opacity: 0.7;
        }

        70% {
            transform: scale(1.2);
            opacity: 1;
            box-shadow: 0 0 20px var(--h-accent-blue);
        }

        100% {
            transform: scale(0.95);
            opacity: 0.7;
        }
    }

    /* Module Navigation Cards */
    .h-module-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .h-module-card {
        background: var(--h-card);
        backdrop-filter: blur(16px);
        border: 1px solid var(--h-border);
        border-radius: 20px;
        padding: 3rem 2rem;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-decoration: none;
        color: inherit;
        position: relative;
        overflow: hidden;
    }

        .h-module-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--h-accent-blue), transparent);
            transform: translateX(-100%);
            transition: 0.5s;
        }

        .h-module-card:hover {
            transform: translateY(-15px);
            border-color: var(--h-accent-blue);
            box-shadow: 0 20px 40px rgba(0,0,0,0.6), 0 0 20px rgba(56, 189, 248, 0.1);
        }

            .h-module-card:hover::before {
                transform: translateX(100%);
            }

        .h-module-card h2 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .h-module-card p {
            color: #9ca3af;
            line-height: 1.6;
            margin-bottom: 2rem;
        }

    .h-module-icon {
        font-size: 3rem;
        margin-bottom: 1.5rem;
        display: block;
    }

    .h-btn-enter {
        display: inline-block;
        padding: 0.8rem 2rem;
        border: 1px solid var(--h-accent-blue);
        border-radius: 50px;
        color: var(--h-accent-blue);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 2px;
        transition: 0.3s;
    }

    .h-module-card:hover .h-btn-enter {
        background: var(--h-accent-blue);
        color: #000;
        box-shadow: 0 0 15px var(--h-accent-blue);
    }

    .h-footer-links {
        margin-top: 6rem;
        text-align: center;
        opacity: 0.5;
        font-size: 0.9rem;
    }

        .h-footer-links a {
            color: #fff;
            text-decoration: none;
            margin: 0 15px;
        }
</style>

<div class="h-dashboard-wrapper">
    <section class="h-hero-section">
        <div class="h-status-line">
            <div class="h-pulse-dot"></div>
            System Online / Terminal v3.0
        </div>
        <h1>Command Center</h1>
        <p style="color: #9ca3af; max-width: 600px; margin: 0 auto;">
            Unified interface for managing academic personnel and architectural course configurations.
        </p>
    </section>

    <div class="h-module-grid">
        <a asp-controller="Students" asp-action="Index" class="h-module-card">
            <span class="h-module-icon">👤</span>
            <h2>Personnel</h2>
            <p>Access the global student registry to onboard, modify, or deauthorize academic personnel.</p>
            <span class="h-btn-enter">Open Module</span>
        </a>

        <a asp-controller="Courses" asp-action="Index" class="h-module-card">
            <span class="h-module-icon">📚</span>
            <h2>Curriculum</h2>
            <p>Architect course deployments, manage credit investments, and adjust complexity levels.</p>
            <span class="h-btn-enter">Open Module</span>
        </a>
    </div>

    <div class="h-footer-links">
        <a href="https://learn.microsoft.com/aspnet/core">Engine Documentation</a>
        <span>|</span>
        <a href="#">System Privacy</a>
        <span>|</span>
        <p style="margin-top: 20px;">&copy; 2026 DraftApp Enterprise Systems</p>
    </div>
</div>