@model Employee_Registration.Models.EmployeeInfo

@{
    ViewData["Title"] = "Create Employee";
}

<style>

    body {
        font-family: Arial, Helvetica, sans-serif;
        background: #f4f6f9;
    }

    .card {
        width: 400px;
        margin: 60px auto;
        background: white;
        padding: 25px;
        border-radius: 8px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

    h2 {
        text-align: center;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: bold;
    }

    input {
        width: 100%;
        padding: 8px;
        margin-top: 5px;
        border: 1px solid #ccc;
        border-radius: 5px;
    }

    button {
        width: 100%;
        padding: 10px;
        background: #007bff;
        color: white;
        border: none;
        border-radius: 5px;
        font-size: 16px;
    }

        button:hover {
            background: #0056b3;
        }

</style>

<div class="card">

    <h2>Employee Registration</h2>

    <form asp-action="Create" method="post">

        <div class="form-group">
            <label>Name</label>
            <input asp-for="Name" />
        </div>

        <div class="form-group">
            <label>Address</label>
            <input asp-for="Address" />
        </div>

        <div class="form-group">
            <label>DOB</label>
            <input asp-for="DOB" type="date" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input asp-for="Email" />
        </div>

        <div class="form-group">
            <label>Phone Number</label>
            <input asp-for="PhoneNumber" />
        </div>

        <button type="submit">Save Employee</button>

    </form>

</div>