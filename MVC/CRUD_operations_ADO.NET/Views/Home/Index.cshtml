@{
    ViewData["Title"] = "Student Dashboard";
}

<!DOCTYPE html>
<html>
<head>
    <title>Student Dashboard</title>

    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background: linear-gradient(135deg,#74ebd5,#ACB6E5);
            padding: 40px;
        }

        .container {
            width: 600px;
            margin: auto;
            background: white;
            padding: 40px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0px 6px 18px rgba(0,0,0,0.2);
        }

        h1 {
            margin-bottom: 30px;
            color: #333;
        }

        .btn {
            display: block;
            margin: 15px auto;
            width: 260px;
            padding: 12px;
            font-size: 18px;
            text-decoration: none;
            border-radius: 6px;
            color: white;
            transition: 0.3s;
        }

        .create {
            background-color: #4CAF50;
        }

            .create:hover {
                background-color: #45a049;
            }

        .view {
            background-color: #2196F3;
        }

            .view:hover {
                background-color: #1976D2;
            }

        .update {
            background-color: #ff9800;
        }

            .update:hover {
                background-color: #e68900;
            }

        .delete {
            background-color: #dc3545;
        }

            .delete:hover {
                background-color: #b02a37;
            }
    </style>
</head>

<body>

    <div class="container">

        <h1>🎓 Student Management System</h1>

        <!-- CREATE -->
        <a asp-controller="Student"asp-action="Create" class="btn create">
            ➕ Add New Student
        </a>

        <!-- READ -->
        <a asp-controller="Student"
           asp-action="GetStudentData"
           class="btn view">
            📋 View All Students
        </a>

        <!-- UPDATE -->
        <a asp-controller="Student" asp-action="Update" class="btn update">
            ✏️ Update Student
        </a>

        <!-- DELETE ALL -->
        <a asp-controller="Student"
           asp-action="DeleteAll"
           class="btn delete">
            🗑 Delete All Students
        </a>

    </div>

</body>
</html>