@{
    ViewData["Title"] = "Delete All Students";
}

<!DOCTYPE html>
<html>
<head>
    <title>Delete All Students</title>

    <style>
        body {
            font-family: Arial;
            background: linear-gradient(135deg,#ff416c,#ff4b2b);
            padding: 40px;
        }

        .container {
            width: 500px;
            margin: auto;
            background: white;
            padding: 30px;
            text-align: center;
            border-radius: 10px;
            box-shadow: 0px 8px 20px rgba(0,0,0,0.3);
        }

        h2 {
            color: #dc3545;
        }

        .btn {
            padding: 12px 20px;
            margin: 10px;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
        }

        .delete-btn {
            background: #dc3545;
            color: white;
        }

        .cancel-btn {
            background: #28a745;
            color: white;
            text-decoration: none;
            padding: 12px 20px;
        }
    </style>
</head>

<body>

    <div class="container">

        <h2>⚠ Delete All Students</h2>

        <p>Are you sure you want to delete ALL student records?</p>

        <form asp-action="DeleteAllConfirmed" method="post">
            <button type="submit" class="btn delete-btn">
                YES — Delete Everything
            </button>
        </form>

        <a asp-action="GetStudentData" class="cancel-btn">
            Cancel
        </a>

    </div>

</body>
</html>